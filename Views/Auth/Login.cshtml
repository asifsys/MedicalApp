<form method="post">

    <label>Email</label>
    <input type="text" name="email" class="form-control" />

    <label>Password</label>
    <input type="password" name="password" class="form-control" />

    <button type="submit" class="btn btn-primary">
        Login
    </button>

    <span style="color:red">@ViewBag.Error</span>

</form>